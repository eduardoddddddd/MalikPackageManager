#!/usr/bin/env python3
import sys
from pathlib import Path


VERSION = "mpm 0.14-mvp"


def add_source_path() -> None:
    current = Path(__file__).resolve()
    candidates = [
        current.parents[1] / "src",
        Path.home() / ".local/lib/mpm/src",
        Path("/usr/lib/mpm/src"),
    ]
    for candidate in candidates:
        if (candidate / "mpm").is_dir():
            sys.path.insert(0, str(candidate))
            return


def main() -> int:
    if any(arg in {"--version", "-V"} for arg in sys.argv[1:]):
        print(VERSION)
        return 0

    add_source_path()
    if "--self-test-catalog" in sys.argv[1:] or "--self-test-catalog-validate" in sys.argv[1:]:
        from mpm.catalog import load_catalog_entries

        entries, path, error = load_catalog_entries()
        if error and not entries:
            print(error, file=sys.stderr)
            return 1
        print(f"{len(entries)} {path}")
        return 0

    if "--self-test-uninstall-preflight" in sys.argv[1:]:
        from mpm.workflow import format_uninstall_confirmation

        dry_run_output = "\n".join(
            [
                "uninstall-plan:",
                "record-id: 1",
                "target: org.mozilla.firefox",
                "backend: flatpak",
                "kind: name",
                "source: name",
                "app-id: org.mozilla.firefox",
                "data-policy: user data is preserved; package-managed files only",
                "commands:",
                "  - flatpak --user uninstall -y org.mozilla.firefox",
            ]
        )
        print(format_uninstall_confirmation(dry_run_output))
        return 0

    if "--self-test-history-format" in sys.argv[1:]:
        from mpm.workflow import format_history_detail, parse_history_output
        import os

        sample = "\n".join(
            [
                '{"operation":"install","record_id":1,"install_id":1,"target":"org.mozilla.firefox","backend":"flatpak","result":"recorded","timestamp":"2026-05-16 10:00:00","app_id":"org.mozilla.firefox"}',
                '{"operation":"uninstall","record_id":2,"install_id":1,"target":"org.mozilla.firefox","backend":"flatpak","result":"success","timestamp":"2026-05-16 10:05:00","detail":"uninstall-plan:\\ncommands:\\n  - flatpak --user uninstall -y org.mozilla.firefox"}',
            ]
        )
        rows = parse_history_output(sample)
        xdg = os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local/share"))
        log_dir = str(Path(xdg) / "mpm" / "logs")
        print(format_history_detail(rows[1] if len(rows) > 1 else rows[0], log_dir))
        return 0

    add_source_path()
    from mpm.main import main as gui_main
    return gui_main(sys.argv[1:])


if __name__ == "__main__":
    raise SystemExit(main())
