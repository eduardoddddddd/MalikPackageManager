#!/usr/bin/env bash
set -euo pipefail

target="${1:-}"

if [[ -z "$target" ]]; then
  printf 'Usage: mpm-open FILE\n' >&2
  exit 2
fi

if [[ ! -e "$target" ]]; then
  printf 'File not found: %s\n' "$target" >&2
  exit 1
fi

choose_terminal() {
  local candidate
  for candidate in "${MPM_TERMINAL:-}" "${TERMINAL:-}" konsole gnome-terminal xfce4-terminal alacritty kitty wezterm foot st xterm; do
    candidate="${candidate%% *}"
    candidate="${candidate##*/}"
    if [[ -z "$candidate" ]]; then
      continue
    fi
    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

if [[ ! -t 0 && -z "${MPM_OPEN_IN_TERMINAL:-}" ]]; then
  terminal="$(choose_terminal || true)"
  if [[ -z "$terminal" ]]; then
    printf 'No supported terminal found. Install konsole, gnome-terminal, xfce4-terminal, alacritty, kitty, or xterm.\n' >&2
    exit 1
  fi

  export MPM_OPEN_IN_TERMINAL=1
  case "$terminal" in
    konsole)
      exec konsole --hold -e "$0" "$target"
      ;;
    gnome-terminal)
      exec gnome-terminal --wait -- "$0" "$target"
      ;;
    xfce4-terminal)
      exec xfce4-terminal --hold -x "$0" "$target"
      ;;
    alacritty)
      exec alacritty --hold -e "$0" "$target"
      ;;
    kitty)
      exec kitty --hold "$0" "$target"
      ;;
    wezterm)
      exec wezterm start --always-new-process -- "$0" "$target"
      ;;
    foot)
      exec foot "$0" "$target"
      ;;
    st)
      exec st -e "$0" "$target"
      ;;
    xterm)
      exec xterm -hold -e "$0" "$target"
      ;;
  esac
fi

if [[ -n "${MPM_PKG_BIN:-}" ]]; then
  mpm_pkg_bin="$MPM_PKG_BIN"
elif command -v mpm-pkg >/dev/null 2>&1; then
  mpm_pkg_bin="$(command -v mpm-pkg)"
elif [[ -x "$HOME/.local/bin/mpm-pkg" ]]; then
  mpm_pkg_bin="$HOME/.local/bin/mpm-pkg"
else
  mpm_pkg_bin="/usr/bin/mpm-pkg"
fi

if ! command -v "$mpm_pkg_bin" >/dev/null 2>&1 && [[ ! -x "$mpm_pkg_bin" ]]; then
  printf 'mpm-pkg not found: %s\n' "$mpm_pkg_bin" >&2
  exit 1
fi

printf 'MPM package opener\n'
printf '\n'
"$mpm_pkg_bin" explain "$target"
printf '\n'
printf 'This will install through MPM policy, not by unpacking into Arch directly.\n'
printf 'Continue? [y/N] '
read -r answer

case "$answer" in
  y|Y|yes|YES)
    "$mpm_pkg_bin" install "$target"
    ;;
  *)
    printf 'Cancelled.\n'
    exit 0
    ;;
esac

printf '\nDone. Press Enter to close this window.'
read -r _ || true
